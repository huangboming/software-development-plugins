{
    "name": "build",
    "version": "0.1.2",
    "description": "Turn decisions into working software — the execution phase where specs become code with the version-control hygiene and code-quality discipline that every later phase depends on.",
    "author": {
        "name": "Boming Huang"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/block-coauthored-by.py\""
                    },
                    {
                        "type": "command",
                        "command": "uv run --script \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/block-force-push.py\""
                    }
                ]
            }
        ]
    }
}